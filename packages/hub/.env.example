# Required — generate once, persist in your secrets manager, never rotate casually.
#
#   AGENFK_HUB_SECRET_KEY=$(openssl rand -hex 32)
#   AGENFK_HUB_SESSION_SECRET=$(openssl rand -hex 32)
#
AGENFK_HUB_SECRET_KEY=replace-with-openssl-rand-hex-32
AGENFK_HUB_SESSION_SECRET=replace-with-openssl-rand-hex-32

# First-run admin (only used until the first user row exists; safe to remove afterward).
AGENFK_HUB_INITIAL_ADMIN_EMAIL=admin@example.com
AGENFK_HUB_INITIAL_ADMIN_PASSWORD=changeme123

# Optional overrides
# AGENFK_HUB_PORT=4000
# AGENFK_HUB_ORG_ID=acme
# AGENFK_HUB_DB_PATH=/data/hub.sqlite
