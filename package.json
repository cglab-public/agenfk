{
  "name": "agenfk-framework",
  "version": "0.1.61",
  "description": "AgenFK Engineering Framework",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "agenfk": "bin/agenfk.js"
  },
  "scripts": {
    "build": "npm run build -w packages/core -w packages/storage-json -w packages/storage-sqlite -w packages/telemetry && npm run build -w packages/cli -w packages/server -w packages/ui",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui:coverage": "cd packages/ui && npx vitest run --coverage",
    "install:framework": "node scripts/install.mjs",
    "uninstall:framework": "node scripts/uninstall.mjs",
    "start:services": "node scripts/start-services.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
