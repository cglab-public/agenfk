{
  "name": "agenfk-framework",
  "version": "0.2.18",
  "description": "AgenFK Engineering Framework",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/storage-sqlite",
    "packages/telemetry",
    "packages/cli",
    "packages/server",
    "packages/ui",
    "packages/create"
  ],
  "bin": {
    "agenfk": "bin/agenfk.js"
  },
  "scripts": {
    "build": "npm run build -w packages/core -w packages/storage-sqlite -w packages/telemetry && npm run build -w packages/cli -w packages/server -w packages/ui",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui:coverage": "cd packages/ui && npx vitest run --coverage",
    "install:framework": "node scripts/install.mjs",
    "uninstall:framework": "node scripts/uninstall.mjs",
    "start:services": "node scripts/start-services.mjs"
  },
  "keywords": [
    "agenfk",
    "agentic",
    "engineering",
    "framework",
    "ai",
    "mcp",
    "claude",
    "workflow",
    "kanban",
    "agile"
  ],
  "author": "CG/lab",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/cglab-public/agenfk.git"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "type": "module",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
